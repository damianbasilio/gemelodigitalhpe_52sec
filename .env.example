# Copia este archivo como .env y rellena los valores

# Requerido - Clave API de Anthropic para Claude
ANTHROPIC_API_KEY=tu_clave_aqui

# Requerido - Clave API de TomTom para datos de trafico
TOMTOM_API_KEY=tu_clave_aqui

# Opcional - Clave secreta de Flask (se genera automaticamente si no se pone)
# FLASK_SECRET_KEY=tu_clave_secreta

# Opcional - Modo depuracion
FLASK_DEBUG=false

# Opcional - Servidor
# HOST_SERVIDOR=0.0.0.0
# PUERTO_SERVIDOR=5000

# Opcional - Origenes CORS permitidos (separados por coma, o * para todos)
# En produccion usar tu dominio: https://tudominio.com
# CORS_ORIGENES=*
